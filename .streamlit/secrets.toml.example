# ──────────────────────────────────────────────────────────────────────────────
# TEMPLATE — copie para .streamlit/secrets.toml (local) ou cole no painel
#             "Secrets" do Streamlit Community Cloud.
# NUNCA commite o arquivo secrets.toml real.
# ──────────────────────────────────────────────────────────────────────────────

[google]
# Google Cloud Console → APIs & Services → Credentials
# Tipo: "Web Application"
# Authorized redirect URIs: https://<seu-app>.streamlit.app (sem barra final)
client_id     = "000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
redirect_uri  = "https://SEU-APP.streamlit.app"

[gemini]
# Chave única do Google Gemini — usada para raciocínio (agente),
# embeddings do RAG e transcrição de voz. Tem nível gratuito.
# Gere em: https://aistudio.google.com/apikey
api_key = "AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

[user_profile]
# Dados pessoais para personalizar o atendimento. Texto livre — escreva o que
# o assistente deve saber sobre você. NUNCA vai para o GitHub (está no .gitignore).
info = """
Nome: (seu nome, como quer ser chamado)
Cidade: (onde mora)
Trabalho: (empresa, cargo, área)
Família: (cônjuge, filhos)
Interesses: (hobbies, temas de interesse)
"""
