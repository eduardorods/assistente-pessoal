# ──────────────────────────────────────────────────────────────────────────────
# TEMPLATE — copie para .streamlit/secrets.toml (local) ou cole no painel
#             "Secrets" do Streamlit Community Cloud.
# NUNCA commite o arquivo secrets.toml real.
# ──────────────────────────────────────────────────────────────────────────────

[google]
# Google Cloud Console → APIs & Services → Credentials
# Tipo: "Web Application"
# Authorized redirect URIs: https://<seu-app>.streamlit.app (sem barra final)
client_id     = "000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
redirect_uri  = "https://SEU-APP.streamlit.app"

[anthropic]
# https://console.anthropic.com/settings/keys
api_key = "sk-ant-api03-xxxxxxxx"

[openai]
# Usado apenas para transcrição via Whisper
# https://platform.openai.com/api-keys
api_key = "sk-proj-xxxxxxxx"
